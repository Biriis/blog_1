# 服务器配置
PORT=3001

# JWT密钥（生产环境请修改）
JWT_SECRET=your-secret-key-change-in-production

# 数据库配置
DB_PATH=./blog.db

# 上传配置
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=52428800

# CORS配置
ALLOWED_ORIGIN=http://localhost:3000

# 管理账户配置（首次启动时创建）
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

# 备份配置
BACKUP_PATH=./backups
