# 服务器配置
PORT=3001
NODE_ENV=production

# 数据库配置
DB_PATH=./data/blog.db
BACKUP_PATH=./backups

# 管理账户配置（请修改默认密码）
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123

# JWT 密钥（请修改为强密码，至少32位）
JWT_SECRET=change-this-to-a-very-long-and-secure-secret-key-at-least-32-chars

# CORS 配置（生产环境请替换为你的域名）
ALLOWED_ORIGIN=https://your-domain.com

# 上传配置
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=5242880

# Rate Limit 配置
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
