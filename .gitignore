# 依赖（这些会通过 npm install 自动安装）
node_modules/
server/node_modules/

# 构建输出（需要重新构建）
dist/

# 数据库（包含用户数据，不要上传）
*.db
*.db-journal

# 环境变量（包含敏感信息，不要上传）
.env
.env.local
.env.*.local
.env.production
.env.development

# 日志
logs/
*.log
npm-debug.log*

# 操作系统
.DS_Store
Thumbs.db

# IDE
.vscode/
.idea/
*.swp
*.swo

# PM2
.pm2/

# 临时文件
*.tmp
*.bak
.cache/

# 备份（如果只想保留Git上的beifen）
beifen/server/node_modules/
beifen/node_modules/

# TypeScript编译缓存
*.tsbuildinfo
tsconfig.tsbuildinfo
