# Fly Blog - 环境变量配置模板
# 复制此文件为 .env.production 并修改对应的值

# ==================== 前端配置 ====================
# API地址（后端服务器地址）
VITE_API_URL=http://你的服务器IP:3001/api

# 上传文件基础URL
VITE_UPLOAD_BASE_URL=http://你的服务器IP:3001

# 网站URL
VITE_SITE_URL=https://你的域名.com

# ==================== 后端配置 ====================
# 服务器端口
PORT=3001

# 网站基础URL
BASE_URL=http://你的服务器IP:3001

# CORS允许的源（前端地址）
ALLOWED_ORIGIN=http://你的服务器IP:33334

# JWT密钥（请修改为随机字符串）
JWT_SECRET=your_super_secret_jwt_key_change_this

# ==================== 使用说明 ====================
# 1. 复制此文件：cp .env.example .env.production
# 2. 修改上面的值
# 3. 不要将 .env* 文件提交到Git
